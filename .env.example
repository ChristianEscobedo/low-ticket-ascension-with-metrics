NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# These environment variables are used for Supabase Local Dev
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Comma-separated list of emails allowed to view /admin/funnel-stats.
# Leave empty in dev to allow any signed-in user.
ADMIN_EMAILS=

# Transactional receipts (optional). RECEIPT_PROVIDER selects the backend:
# "resend" (default) or "postmark". Provide the matching credential below.
RECEIPT_PROVIDER=resend
RESEND_API_KEY=
POSTMARK_API_TOKEN=
# Postmark message stream slug (defaults to "outbound" — only override if
# your Postmark server uses a custom transactional stream).
RECEIPT_POSTMARK_STREAM=
RECEIPT_FROM_EMAIL=
# Optional receipt branding.
RECEIPT_BRAND_NAME=
RECEIPT_SUBJECT_PREFIX=
RECEIPT_REPLY_TO=
# Comma-separated BCC list applied to every outgoing receipt. Typically the
# GHL email-to-contact ingest address so receipts land in your unified inbox.
RECEIPT_BCC=

# Receipt audit-log retention window in days. Rows older than this are
# deleted by the nightly /api/cron/purge-receipt-log job. Defaults to 90.
RECEIPT_LOG_RETENTION_DAYS=90
# Shared secret Vercel sends in the Authorization header for cron triggers.
# Required to enable the receipt-log purge job. Generate any high-entropy value.
CRON_SECRET=
# Resend webhook signing secret (whsec_...). Required to enable inbound
# delivery telemetry at /api/webhooks/resend (delivered / bounced / etc).
RESEND_WEBHOOK_SECRET=

