NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Runtime override note: the Stripe, AI (OpenAI / Anthropic), and email
# credentials below are now fallbacks. An admin can set them in-app under
# /admin/stripe and /admin/integrations, where they are read DB-first (when the
# integration is enabled) with no redeploy. These env values apply whenever the
# matching in-app setting is missing or disabled.

# These environment variables are used for Supabase Local Dev
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Comma-separated list of emails allowed to view /admin/funnel-stats.
# Leave empty in dev to allow any signed-in user.
ADMIN_EMAILS=

# Transactional receipts (optional). RECEIPT_PROVIDER selects the backend:
# "resend" (default) or "postmark". Provide the matching credential below.
RECEIPT_PROVIDER=resend
RESEND_API_KEY=
POSTMARK_API_TOKEN=
# Postmark message stream slug (defaults to "outbound" — only override if
# your Postmark server uses a custom transactional stream).
RECEIPT_POSTMARK_STREAM=
RECEIPT_FROM_EMAIL=
# Optional receipt branding.
RECEIPT_BRAND_NAME=
RECEIPT_SUBJECT_PREFIX=
RECEIPT_REPLY_TO=
# Comma-separated BCC list applied to every outgoing receipt. Typically the
# GHL email-to-contact ingest address so receipts land in your unified inbox.
RECEIPT_BCC=

# Receipt audit-log retention window in days. Rows older than this are
# deleted by the nightly /api/cron/purge-receipt-log job. Defaults to 90.
RECEIPT_LOG_RETENTION_DAYS=90
# Shared secret Vercel sends in the Authorization header for cron triggers.
# Required to enable the receipt-log purge job AND the hourly email-sequence
# runner (/api/cron/email-sequences). Generate any high-entropy value.
CRON_SECRET=
# Max enrollments processed per email-sequence cron tick. Defaults to 50.
EMAIL_SEQUENCE_BATCH_SIZE=50
# Resend webhook signing secret (whsec_...). Required to enable inbound
# delivery telemetry at /api/webhooks/resend (delivered / bounced / etc).
RESEND_WEBHOOK_SECRET=

# Content hub AI (admin-only, /api/mothermode/ai). Images use OpenAI; copy is
# written by a frontier text model.
# OpenAI key: required for AI image generation, and for text when the provider
# is OpenAI (GPT-5.5).
OPENAI_API_KEY=
# fal.ai key: required for Variation Lab smart-resize (fal-ai/smart-resize).
# https://fal.ai/dashboard/keys
FAL_KEY=

# Anthropic key: when set, copy rewrites use Claude Opus 4.8 by default.
ANTHROPIC_API_KEY=
# Google (Gemini) key: required for the Nano Banana image model
# (gemini-2.5-flash-image). GEMINI_API_KEY wins, GOOGLE_API_KEY is a fallback.
GEMINI_API_KEY=
# Optional overrides. Provider is "anthropic" or "openai" (auto-detected from
# the keys above when unset). Model overrides the per-provider default
# (claude-opus-4-8 / gpt-5.5). Image model defaults to gpt-image-2.
MOTHERMODE_AI_TEXT_PROVIDER=
MOTHERMODE_AI_TEXT_MODEL=
MOTHERMODE_AI_IMAGE_MODEL=

# Optional: Google Sheets export from the content hub Export panel.
# Service account with Sheets API enabled. Private key newlines as \n.
# GOOGLE_SERVICE_ACCOUNT_JSON={"client_email":"...","private_key":"-----BEGIN..."}
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=


