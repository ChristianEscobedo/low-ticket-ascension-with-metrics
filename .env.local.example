# Public site URL — used for OAuth/email-link redirect URLs. In production
# set this to your real domain (e.g. https://yourapp.com).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase — get from Dashboard > Project Settings > API
# (or `pnpm supabase:status` when running locally).
# NOTE: The boilerplate code reads NEXT_PUBLIC_SUPABASE_ANON_KEY. In newer
# Supabase dashboards this is shown as "publishable key" — same value.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — get from Dashboard > Developers > API keys.
# For STRIPE_WEBHOOK_SECRET (whsec_...), run `pnpm stripe:listen` locally or
# create a webhook endpoint in production and copy its signing secret.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin dashboard gate — comma-separated emails allowed to view /admin/*.
# Leave EMPTY in dev to allow any signed-in user.
ADMIN_EMAILS=

# Transactional receipts (optional). When the selected provider's credential
# and RECEIPT_FROM_EMAIL are both set, the webhook sends a branded purchase
# receipt after every successful charge. Leave EMPTY to disable receipts.
# RECEIPT_PROVIDER selects the backend: "resend" (default) or "postmark".
RECEIPT_PROVIDER=resend
RESEND_API_KEY=
POSTMARK_API_TOKEN=
# Postmark message stream slug (defaults to "outbound" — only override if
# your Postmark server uses a custom transactional stream).
RECEIPT_POSTMARK_STREAM=
RECEIPT_FROM_EMAIL=
# Optional branding for the receipt email.
RECEIPT_BRAND_NAME=
RECEIPT_SUBJECT_PREFIX=
RECEIPT_REPLY_TO=
# Comma-separated BCC list applied to every outgoing receipt. Typically the
# GHL email-to-contact ingest address so receipts land in your unified inbox.
RECEIPT_BCC=

# Receipt audit-log retention window in days. Rows older than this are
# deleted by the nightly /api/cron/purge-receipt-log job. Defaults to 90.
RECEIPT_LOG_RETENTION_DAYS=90
# Shared secret Vercel sends in the Authorization header for cron triggers.
# Required to enable the receipt-log purge job AND the hourly email-sequence
# runner (/api/cron/email-sequences). Generate any high-entropy value.
CRON_SECRET=
# Max enrollments processed per email-sequence cron tick. Defaults to 50.
EMAIL_SEQUENCE_BATCH_SIZE=50
# Resend webhook signing secret (whsec_...). Required to enable inbound
# delivery telemetry at /api/webhooks/resend (delivered / bounced / etc).
RESEND_WEBHOOK_SECRET=

# OAuth — provider credentials (Google client id/secret, GitHub OAuth app) are
# configured in the Supabase Dashboard (Authentication > Providers), NOT here.
# This app reads OAuth sessions via cookies; no provider env vars needed.

# React Bits Pro — license key for installing components from the @reactbits-pro
# / @reactbits-starter shadcn registries (configured in components.json).
# Only needed at install time when running `pnpm dlx shadcn@latest add ...`.
# Get yours at https://pro.reactbits.dev.
REACTBITS_LICENSE_KEY=

